# Appwrite Authentication
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
EXPO_PUBLIC_APPWRITE_BUCKET_ID=your_bucket_id
APPWRITE_JWT_SECRET=your_jwt_secret

# RevenueCat (Payments)
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=your_apple_api_key
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=your_google_api_key

# Sanity (CMS)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token

# OpenAI (AI, TTS, STT)
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-1

# Dev Auth Bypass (NEVER enable in production)
EXPO_PUBLIC_DEV_AUTH_BYPASS=false
