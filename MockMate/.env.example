# MockMate Environment Variables
# ---------------------------------
# Copy this file to .env and fill in your real values.
# .env is git-ignored. NEVER commit real secrets.
# Only variables prefixed with EXPO_PUBLIC_ are bundled into the client app.
# Anything without that prefix is server-side only (API routes / EAS Functions).

# ============================================================
# Appwrite Authentication (Google OAuth)
# ============================================================
# Create an Appwrite project at https://cloud.appwrite.io/
# Go to Appwrite Console → Project Settings → API Credentials to get these.
# Redirect scheme "mockmate" must be configured in app.json.
# See docs/AUTH_SETUP.md for step-by-step instructions.

EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=67xxxxxxxxxxxxxxx
EXPO_PUBLIC_APPWRITE_BUCKET_ID=67xxxxxxxxxxxxxxx
EXPO_PUBLIC_BACKEND_URL=https://your-backend-url.com

# Appwrite JWT Secret — server-side only (never bundled in client)
# Get from Appwrite Console → Project Settings → API Credentials → JWT Secret
APPWRITE_JWT_SECRET=your_appwrite_jwt_secret_here

# Set to "true" to bypass real login in local development. Returns a
# synthetic user without hitting Appwrite servers. NEVER enable in prod.
EXPO_PUBLIC_DEV_AUTH_BYPASS=false

# ============================================================
# Sanity — CMS + data store
# ============================================================
# Create a project at https://www.sanity.io/manage
# The first three vars are SAFE to ship in the client bundle (CDN read-only).
# The write token is used by API routes and EAS Functions ONLY.

EXPO_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
EXPO_PUBLIC_SANITY_DATASET=production
EXPO_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-side only. Create a token with "Editor" permissions in the
# Sanity dashboard (API -> Tokens). Used by Expo API routes to write
# user-scoped data (interview history, gamification, saved interviews).
SANITY_API_TOKEN=skXXXXX_server_only_write_token

# ============================================================
# RevenueCat — VIP subscriptions
# ============================================================
# Create a project at https://app.revenuecat.com/
# Add products: monthly_vip, yearly_vip
# Configure an "Entitlement" called "vip" that unlocks both products.

EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# OpenAI Compatibility Endpoint (AI SDK)
# ============================================================
# For OpenAI-compatible APIs (e.g., OpenAI, Azure OpenAI, local LLMs)
# Base URL for your OpenAI-compatible endpoint
#
# THESE ARE PLACEHOLDERS. .env (gitignored) holds real values.
# Earlier revisions of this file leaked a real API key + a private
# proxy URL into git history; rotate that key at the provider before
# relying on it for any further use.

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Models
OPENAI_MODEL=gemini/gemini-2.5-pro
OPENAI_TTS_MODEL=google-tts/en
OPENAI_STT_MODEL=gemini/gemini-2.5-pro

# ============================================================
# Expo API Base URL (Production)
# ============================================================
# Set this in production to point to your deployed API server
# In development, the app uses the local dev server automatically

# EXPO_PUBLIC_API_BASE_URL=https://your-production-api.com

# ============================================================
# Optional — local dev overrides
# ============================================================
# When true, the welcome screen still appears but `authorize` is short-circuited
# (use only for unit tests). Production builds MUST leave this unset / false.
# EXPO_PUBLIC_DEV_BYPASS_AUTH=false
