# MockMate Environment Variables
# Copy this to .env and fill in real values

# Expo
EXPO_PUBLIC_APP_NAME=MockMate

# Sanity CMS
EXPO_PUBLIC_SANITY_PROJECT_ID=your_project_id
EXPO_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_token

# Auth0
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your_client_id

# OpenAI-Compatible API (server-side only — do not expose with EXPO_PUBLIC_)
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://9router.chickenkiller.com/v1
OPENAI_MODEL=gemini/gemini-2.5-pro
OPENAI_TTS_MODEL=google-tts/en
OPENAI_STT_MODEL=gemini/gemini-2.5-pro

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your_ios_key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your_android_key
